{
  "schema_version": "2.0",
  "_migration_note": "v1.0→v2.0: 评审分包从「小/中/大需求×维度编号」改为「L1-L4×章节ID」，与 prd-quality-framework 对齐",
  "review_profiles": {
    "L1": {
      "label": "L1（配置级）",
      "complexity_level": 1,
      "default_chapters": ["ch10-2", "ch10-3", "ch14"],
      "global_checks": ["G1"],
      "triggered_chapters": [],
      "notes": "仅配置/文案/样式/阈值变更，无新页面/实体/角色"
    },
    "L2": {
      "label": "L2（规则级）",
      "complexity_level": 2,
      "default_chapters": ["ch01", "ch02", "ch06", "ch10-1", "ch10-2", "ch10-3", "ch14"],
      "global_checks": ["G1"],
      "optional_chapters": [],
      "triggered_chapters": ["ch03", "ch11", "ch12", "ch13"],
      "notes": "修改/新增业务规则，L2 起 ch10-1 必须有流程图"
    },
    "L3": {
      "label": "L3（模块级）",
      "complexity_level": 3,
      "default_chapters": ["ch01", "ch02", "ch04", "ch05", "ch06", "ch10-1", "ch10-2", "ch10-3", "ch12", "ch13", "ch14"],
      "global_checks": ["G1", "G2"],
      "optional_chapters": ["ch11"],
      "triggered_chapters": ["ch03", "ch07", "ch08-09"],
      "notes": "新增页面/实体/角色权限，5-8页模块PRD"
    },
    "L4": {
      "label": "L4（系统级）",
      "complexity_level": 4,
      "default_chapters": [
        "ch01", "ch02", "ch03", "ch04", "ch05", "ch06", "ch07",
        "ch08-09", "ch10-1", "ch10-2", "ch10-3", "ch11", "ch12", "ch13", "ch14"
      ],
      "global_checks": ["G1", "G2", "G3"],
      "optional_chapters": [],
      "triggered_chapters": [],
      "notes": "0-1 新系统/业务域/子系统，完整14章PRD"
    }
  },
  "force_check_rules": [
    {
      "chapter_ids": ["ch10-1"],
      "check_name": "数据结构变化",
      "trigger_label": "数据结构变化",
      "signals": [
        "新增数据实体",
        "新增业务对象",
        "关键字段变化",
        "字段口径变化",
        "状态机变化",
        "枚举变化",
        "关联关系变化",
        "统计口径变化",
        "导入导出口径变化",
        "报表口径变化"
      ]
    },
    {
      "chapter_ids": ["ch10-1"],
      "check_name": "系统结构变化",
      "trigger_label": "系统结构变化",
      "signals": [
        "跨模块联动",
        "系统级方案",
        "公共能力",
        "外部系统集成",
        "服务边界变化"
      ]
    },
    {
      "chapter_ids": ["ch10-2"],
      "check_name": "AI功能设计",
      "trigger_label": "智能能力",
      "signals": [
        "AI",
        "LLM",
        "推荐",
        "生成",
        "分类",
        "摘要",
        "智能助手"
      ]
    },
    {
      "chapter_ids": ["ch03"],
      "check_name": "商业规则变化",
      "trigger_label": "商业规则变化",
      "signals": [
        "定价",
        "套餐",
        "试用",
        "转化",
        "客户分层",
        "多租户",
        "商业模式约束"
      ]
    },
    {
      "chapter_ids": ["ch10-1", "ch12"],
      "check_name": "流转与责任变化",
      "trigger_label": "流转与责任变化",
      "signals": [
        "角色变化",
        "权限变化",
        "审批变化",
        "协作变化",
        "流转规则变化"
      ]
    },
    {
      "chapter_ids": ["ch10-2"],
      "check_name": "界面与操作变化",
      "trigger_label": "界面与操作变化",
      "signals": [
        "页面变化",
        "表单变化",
        "弹窗变化",
        "抽屉变化",
        "列表变化",
        "批量操作变化",
        "反馈提示变化"
      ]
    },
    {
      "chapter_ids": ["ch11", "ch13"],
      "check_name": "上线后效果闭环",
      "trigger_label": "上线后效果闭环",
      "signals": [
        "推广",
        "培训",
        "埋点",
        "指标回收",
        "效果复盘"
      ]
    }
  ],
  "score_mapping": {
    "优秀": 100,
    "合格": 80,
    "待改进": 60,
    "严重缺失": 30
  },
  "chapter_weights": {
    "ch01": 1.0,
    "ch02": 1.0,
    "ch03": 1.0,
    "ch04": 1.0,
    "ch05": 1.0,
    "ch06": 1.0,
    "ch07": 1.0,
    "ch08-09": 0.5,
    "ch10-1": 1.5,
    "ch10-2": 1.5,
    "ch10-3": 1.0,
    "ch11": 1.0,
    "ch12": 1.0,
    "ch13": 1.0,
    "ch14": 0.5
  },
  "delivery_gate": {
    "required_conditions": [
      "all_issues_replied",
      "all_issues_processed"
    ],
    "score_is_advisory": true
  }
}
